{
    "$schema": "https://opencode.ai/config.json",
    "model": "Qwen3.6-27B-UD-Q6_K_XL.gguf",
    "provider": {
        "llamacpp": {
           "npm": "@ai-sdk/openai-compatible",
            "name": "llamacpp",
            "options": {
                "baseURL": "http://twister:8001/v1"
            },
            "models": {
                "Qwen3.6-27B-UD-Q6_K_XL.gguf": {
                    "name": "Qwen3.6 27B TurboQuant",
                    "modalities": {
                        "input": ["text", "image"],
                        "output": ["text"]
                    },
                    "attachment": true
                }
            }
        },
        "llamacpp-gemma4": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "Gemma 4 VLM (llama.cpp)",
            "options": {
                "baseURL": "http://twister:8002/v1"
            },
            "models": {
                "gemma-4-E4B-it-Q4_K_M.gguf": {
                    "name": "Gemma 4 VLM E4B Q4_K_M",
                    "limit": {
                        "context": 256000,
                        "output": 32768
                    }
                }
            }
        }
  },
  "tools": {
      "write": true,
      "bash": true,
      "grep": true,
      "websearch": true,
      "webfetch": true,
  },
    "mcp": {
     	"blender": {
            "type": "local",
            "command": ["blender-mcp"],
            "enabled": true,
            "environment": {
                "BLENDER_MCP_HOST": "localhost",
            }
	},
        "kirenn": {
            "type": "remote",
            "url": "http://twister:7778/api/mcp"
        },
        "UnrealEngine": {
            "type": "remote",
            "url": "http://localhost:9990/mcp"
        },
        "searxng": {
            "type": "local",
            "command": ["npx", "mcp-searxng"],
            "environment": {
                "SEARXNG_URL": "http://twister:8501"
            }
        },
  },
  "agent": {
    "plan": {
      "tools": {
        "write": false,
        "bash": false
      }
    },
    "build": {
      "permission": {
        "bash": "allow"
      }
    }
  },
  "plugin": [],
  "permission": {
    "edit": "ask"
  }
}

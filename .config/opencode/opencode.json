{
    "$schema": "https://opencode.ai/config.json",
    "model": "Qwen3.6-27B-UD-Q6_K_XL.gguf",
    "provider": {
        "llamacpp": {
           "npm": "@ai-sdk/openai-compatible",
            "name": "llamacpp",
            "options": {
                "baseURL": "http://twister:8001/v1"
            },
            "models": {
                "Qwen3.6-27B-UD-Q6_K_XL.gguf": {
                    "name": "Qwen3.6 27B TurboQuant"
                },
            }
        },
  },
  "tools": {
      "write": true,
      "bash": true,
      "grep": true,
      "websearch": true,
      "webfetch": false,
  },
    "mcp": {
     	"blender": {
            "type": "local",
            "command": ["blender-mcp"],
            "enabled": true,
            "environment": {
                "BLENDER_MCP_HOST": "127.0.0.1",
            }
	},
        "kirenn": {
            "type": "remote",
            "url": "http://twister:7778/api/mcp"
        },
        "searxng": {
            "type": "local",
            "command": ["npx", "mcp-searxng"],
            "environment": {
                "SEARXNG_URL": "http://twister:8501"
            }
        },

        "playwright": {
            "type": "local",
            "command": [
                "npx",
                "@playwright/mcp@latest"
            ],
            "enabled": true
        },



        
  },
  "agent": {
    "plan": {
      "tools": {
        "write": false,
        "bash": false
      }
    },
    "build": {
      "permission": {
        "bash": "allow"
      }
    }
  },
  "plugin": [],
  "permission": {
    "edit": "ask"
  }
}

{
    "$schema": "https://opencode.ai/config.json",
    "model": "Qwen3.6-27B-UD-Q6_K_XL.gguf",
    "provider": {
        "llamacpp": {
           "npm": "@ai-sdk/openai-compatible",
            "name": "llamacpp",
            "options": {
                "baseURL": "http://twister:8001/v1"
            },
            "models": {
                "Qwen3.6-27B-UD-Q6_K_XL.gguf": {
                    "name": "Qwen3.6 27B TurboQuant"
                },
            }
        },
  },
  "tools": {
      "write": true,
      "bash": true,
      "grep": true,
      "websearch": true,
      "webfetch": false,
  },
    "mcp": {
     	"blender": {
            "type": "local",
            "command": [
                "uv",
		"--directory",
		"/mnt/2tb/opt/blender_mcp/mcp",
		"run",
		"blender-mcp"
	    ],
            "enabled": true,
            "environment": {
                "DISABLE_TELEMETRY": "true",
            }
	},
        "kirenn": {
            "type": "remote",
            "url": "http://twister:7778/api/mcp"
        },
        "searxng": {
            "type": "local",
            "command": ["npx", "mcp-searxng"],
            "environment": {
                "SEARXNG_URL": "http://twister:8501"
            }
        },

        "playwright": {
            "type": "local",
            "command": [
                "npx",
                "@playwright/mcp@latest",
                "--executable-path",
                "/home/finn/.cache/ms-playwright/chromium-1223/chrome-linux64/chrome",
                "--headless"
            ],
            "enabled": true
        },



        
  },
  "agent": {
    "plan": {
      "tools": {
        "write": false,
        "bash": false
      }
    },
    "build": {
      "permission": {
        "bash": "allow"
      }
    }
  },
  "plugin": [],
  "permission": {
    "edit": "ask"
  }
}
